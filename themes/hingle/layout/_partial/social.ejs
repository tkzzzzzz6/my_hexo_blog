<% if (theme.social) { %>
    <div class="home-social">
    <% theme.social.forEach(item => { %>
        <% if (item.title === 'RSS') { %>
        <a href="javascript:void(0)" title="点击复制 RSS 订阅地址" onclick="navigator.clipboard.writeText(location.origin+'<%= item.link %>').then(()=>{var t=document.createElement('div');t.textContent='RSS 订阅地址已复制';t.style.cssText='position:fixed;top:20px;left:50%;transform:translateX(-50%);background:#333;color:#fff;padding:8px 20px;border-radius:6px;z-index:9999;font-size:14px;';document.body.appendChild(t);setTimeout(()=>t.remove(),2000)})">
        <% } else { %>
        <a href="<%= item.link %>" title="<%= item.title %>">
        <% } %>
        <% if (item.svg) { %>
            <%- item.svg %>
        <% } else { %>
            <i class="fa fa-<%= item.icon %>"></i>
        <% } %>
        </a>
    <% }) %>
    </div>
<% } %>
