<% const friends=Array.isArray(site.data && site.data.friends) ? site.data.friends : []; %>
    <main>
        <div class="wrap min">
            <section class="page-title">
                <h2>
                    <%= page.title ? page.title : "没有标题的页面" %>
                </h2>
            </section>

            <!-- 友链展示区 -->
            <section class="friends-list">
                <% if (friends.length) { %>
                    <div class="friends-grid">
                        <% friends.forEach(function(friend) { %>
                            <% const avatar=friend.avatar || url_for("/static/img/icon.png"); %>
                                <article class="friend-card">
                                    <a class="friend-card-avatar" href="<%= friend.link %>" target="_blank"
                                        rel="noopener noreferrer">
                                        <img src="<%= avatar %>" alt="<%= friend.name %>">
                                    </a>
                                    <h3 class="friend-card-name"><a href="<%= friend.link %>" target="_blank"
                                            rel="noopener noreferrer">
                                            <%= friend.name %>
                                        </a></h3>
                                    <% if (friend.desc) { %>
                                        <p class="friend-card-desc"><%- friend.desc %></p>
                                        <% } %>
                                </article>
                                <% }) %>
                    </div>
                    <% } else { %>
                        <blockquote>还没有添加友链，欢迎来交换链接。</blockquote>
                        <% } %>
            </section>

            <!-- 页面内容 -->
            <article class="page-content">
                <% if (page.date && moment().unix() - page.date.unix()>= 15552000) { %>
                    <blockquote>这篇文章上次修改于 <%= Math.ceil((moment().unix() - page.date.unix()) / 86400) %>
                            天前，可能其部分内容已经发生变化，如有疑问可询问作者。</blockquote>
                    <% } %>
                        <%- page.content %>
            </article>
            <% const giscus=(theme.giscus && theme.giscus.enable) ? theme.giscus : ((config.giscus &&
                config.giscus.enable) ? config.giscus : null); %>
                <% if (giscus && giscus.repoId && giscus.repoId !== "YOUR_REPO_ID") { %>
                    <section class="post-comments">
                        <div id="giscus-container"></div>
                    </section>
                    <script>
                        (function() {
                            function getGiscusTheme() {
                                return document.body.classList.contains('dark-theme') ? 'dark' : 'light';
                            }

                            const giscus = document.createElement('script');
                            giscus.src = 'https://giscus.app/client.js';
                            giscus.setAttribute('data-repo', '<%= giscus.repo %>');
                            giscus.setAttribute('data-repo-id', '<%= giscus.repoId %>');
                            giscus.setAttribute('data-category', '<%= giscus.category || "Announcements" %>');
                            giscus.setAttribute('data-category-id', '<%= giscus.categoryId %>');
                            giscus.setAttribute('data-mapping', '<%= giscus.mapping || "pathname" %>');
                            giscus.setAttribute('data-reactions-enabled', '<%= giscus.reactionsEnabled !== false ? "1" : "0" %>');
                            giscus.setAttribute('data-emit-metadata', '<%= giscus.emitMetadata ? "1" : "0" %>');
                            giscus.setAttribute('data-input-position', '<%= giscus.inputPosition || "top" %>');
                            giscus.setAttribute('data-lang', '<%= giscus.lang || config.language || "zh-CN" %>');
                            giscus.setAttribute('data-loading', 'lazy');
                            giscus.setAttribute('data-theme', getGiscusTheme());
                            giscus.setAttribute('crossorigin', 'anonymous');
                            giscus.async = true;
                            document.getElementById('giscus-container').appendChild(giscus);

                            new MutationObserver(function() {
                                var frame = document.querySelector('iframe.giscus-frame');
                                if (frame) {
                                    frame.contentWindow.postMessage({
                                        giscus: { setConfig: { theme: getGiscusTheme() } }
                                    }, 'https://giscus.app');
                                }
                            }).observe(document.body, { attributes: true, attributeFilter: ['class'] });
                        })();
                    </script>
                    <% } %>
        </div>
    </main>